<Window x:Class="Content_Management_System.View.MessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Content_Management_System.View"
        xmlns:uc="clr-namespace:Content_Management_System.UserControls" 
        xmlns:fa5="http://schemas.fontawesome.com/icons/"
        mc:Ignorable="d"
        
        Title="MessageWindow" 
        
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        
        MaxHeight="210" MaxWidth="400"
        MinHeight="210" MinWidth="400">

    <Border Style="{DynamicResource BorderedGridStyle}">
        <Grid Style="{DynamicResource GridStyle}">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="0.5*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

                <uc:WindowHeader Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" MinimizedButton="False" MaximizedButton="False" CloseButton="True"/>


            <Label x:Name="MessageLabel" Grid.Row="1" Grid.Column="0" Content="{Binding Message}" Foreground="{DynamicResource TextColorBrush}" FontSize="14.5" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
            <fa5:SvgAwesome Grid.Row="1" Grid.Column="1" Foreground="{DynamicResource Primary1Color}" Icon="{Binding MessageIcon}" Width="64" Height="64" VerticalAlignment="Center" HorizontalAlignment="Center" ></fa5:SvgAwesome>

            <StackPanel x:Name="ButtonStackPanel" Orientation="Horizontal" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0 0 10 0">
                <Button x:Name="OKBtn"  Click="OKBtn_Click" Style="{DynamicResource ButtonStyle}" Width="60" Height="25" Margin="0 0 5 0" Content="OK"></Button>
                <Button x:Name="YesBtn" Click="YesBtn_Click" Style="{DynamicResource ButtonStyle}" Width="60" Height="25" Margin="0 0 5 0" Content="Yes"></Button>
                <Button x:Name="NoBtn"  Click="NoBtn_Click" Style="{DynamicResource ButtonStyle}" Width="60" Height="25" Margin="0 0 5 0" Content="No"></Button>
            </StackPanel>
            
        </Grid>
    </Border>
    
</Window>
