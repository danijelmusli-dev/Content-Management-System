<UserControl x:Class="Content_Management_System.UserControls.WindowHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Content_Management_System.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="30" d:DesignWidth="30"
             Width="Auto" Height="Auto">
    <Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0">
            <Button x:Name="WindowMinimizeBtn" Style="{DynamicResource WindowButtonStyle}" Click="WindowMinimizeBtn_Click" Width="40" Height="30" FontFamily="Segoe MDL2 Assets" FontSize="12">
                <TextBlock Text="&#xE921;"/>
            </Button>
            <Button x:Name="WindowMaximizeBtn" Style="{DynamicResource WindowButtonStyle}" Click="WindowMaximizeBtn_Click" Width="40" Height="30" FontFamily="Segoe MDL2 Assets" FontSize="12">
                <TextBlock Text="&#xE922;"/>
            </Button>
            <Button x:Name="WindowCloseBtn" Style="{DynamicResource WindowButtonStyle}" Click="WindowCloseBtn_Click" Width="40" Height="30" FontFamily="Segoe MDL2 Assets" FontSize="12">
                <TextBlock Text="&#xE8BB;"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
