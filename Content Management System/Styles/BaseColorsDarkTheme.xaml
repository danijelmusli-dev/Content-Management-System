<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Brush x:Key="Primary0Color">#242424</Brush>
    <Brush x:Key="Primary1Color">#363636</Brush>
    <Brush x:Key="Primary2Color">#4F4F4F</Brush>

    <Brush x:Key="Secondary0Color">#F54927</Brush>
    <Brush x:Key="Secondary1Color">#F87C63</Brush>
    <Brush x:Key="Secondary2Color">#FAA18F</Brush>

    <SolidColorBrush x:Key="TextColorBrush" Color="White"/>
