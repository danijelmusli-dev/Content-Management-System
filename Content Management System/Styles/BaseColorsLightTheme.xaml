<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Brush x:Key="Primary0Color">#F0F0F0</Brush>
    <Brush x:Key="Primary1Color">#CCCCCC</Brush>
    <Brush x:Key="Primary2Color">#B3B3B3</Brush>

    <Brush x:Key="Secondary0Color">#F54927</Brush>
    <Brush x:Key="Secondary1Color">#F87C63</Brush>
    <Brush x:Key="Secondary2Color">#FAA18F</Brush>

    <Brush x:Key="StarColor">#FF8000</Brush>
    <Brush x:Key="StarHoverColor">#FFA85C</Brush>

    <Color x:Key="GradientStartColor">#242424</Color>
    <Color x:Key="GradientEndColor">#F54927</Color>

    <SolidColorBrush x:Key="TextColorBrush" Color="#242424"/>
    <SolidColorBrush x:Key="TextMediumColorBrush" Color="#363636"/>
    <SolidColorBrush x:Key="TextLightColorBrush" Color="#4F4F4F"/>

    <SolidColorBrush x:Key="TextErrorColorBrush" Color="#FA3939"/>

    <Color x:Key="Primary0GradientColor">#F0F0F0</Color>
    <Color x:Key="Primary1GradientColor">#CCCCCC</Color>
    <Color x:Key="Primary2GradientColor">#B3B3B3</Color>

    <Color x:Key="Secondary0GradientColor">#F54927</Color>
    <Color x:Key="Secondary1GradientColor">#F87C63</Color>
    <Color x:Key="Secondary2GradientColor">#FAA18F</Color>

</ResourceDictionary>